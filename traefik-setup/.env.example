# ==============================================
# Traefik Environment Configuration
# Copy this file to .env and fill in real values
# Location on server: /etc/traefik/.env
# ==============================================

# -- Cloudflare --
# Used by DDNS script
CF_API_TOKEN=REPLACE_WITH_TOKEN
# Used by Traefik (ACME)
CF_DNS_API_TOKEN=REPLACE_WITH_TOKEN
CF_ZONE_API_TOKEN=REPLACE_WITH_TOKEN
CF_ZONE_NAME=mkroshana.com
CF_RECORD_NAME=*.starklab.mkroshana.com

# -- ACME / Let's Encrypt --
ACME_EMAIL=admin@mkroshana.com

# -- CrowdSec --
# Generate with: sudo cscli bouncers add traefik-bouncer
CROWDSEC_BOUNCER_API_KEY=your_crowdsec_bouncer_api_key_here

# -- Dashboard Auth --
# Generate with: htpasswd -nb admin YOUR_PASSWORD
# Use the FULL output (including admin: prefix)
# Do NOT double the $ signs here — deploy.sh handles escaping
DASHBOARD_AUTH_HASH=admin:$apr1$REPLACE_WITH_HTPASSWD_OUTPUT

# -- Optional: Cloudflare DDNS --
# Set to "true" to enable Cloudflare proxy (hides your real IP)
CF_PROXIED=false
# DNS record TTL in seconds (120 = 2 minutes)
CF_TTL=120
